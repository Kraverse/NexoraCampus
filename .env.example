# NexoraCampus environment variables

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Secret used to sign session JWTs (change in production, 32+ chars)
AUTH_SECRET=nexora-dev-secret-change-me-please-32bytes

# Optional: enable real AI (rewrite, summarize, assistant) via OpenAI.
# If unset, NexoraCampus uses its built-in offline AI heuristics.
OPENAI_API_KEY=
